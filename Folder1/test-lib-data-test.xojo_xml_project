   <SourceLine>If dst_tmp_column = Nil Then</SourceLine>
   <SourceLine>dst_tmp_column = Self.add_column(column_name)</SourceLine>
   <SourceLine>dst_tmp_column.set_length(length_before)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End If</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dst_tmp_column.append_serie(src_tmp_column)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>Next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>Dim new_size As Integer = Self.row_count + the_table.row_count</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>Self.row_index.set_length(new_size)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>For Each tmp_column As clAbstractDataSerie In Self.columns</SourceLine>
   <SourceLine>tmp_column.set_length(new_size)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>system.DebugLog("size="+str(tmp_column.row_count))</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>Next</SourceLine>
