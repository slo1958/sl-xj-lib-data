   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function to_json() As JSONItem</SourceLine>
   <SourceLine>// Part of the clDataSupport.itf_json_able interface.</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>// Part of the clDataSupport.itf_string_able interface.</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>Dim js_list As New JSONItem</SourceLine>
   <SourceLine>Dim js_return As New JSONItem</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>For row As Integer = 0 To row_count-1</SourceLine>
   <SourceLine>Dim element As variant = get_element(row)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>If element IsA clDataSupport.itf_json_able Then</SourceLine>
   <SourceLine>js_list.append(clDataSupport.itf_json_able(element).to_json)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>Else</SourceLine>
   <SourceLine>Try</SourceLine>
   <SourceLine>js_list.Append(element.StringValue)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>Catch TypeMismatchExceptiondim  </SourceLine>
   <SourceLine>js_list.Append("Cannot convert")</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Try</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End If</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>Next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>js_return.Value(name) = js_list</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>Return js_return</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Function</SourceLine>
