   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function clone() As clCompressedDataSerie</SourceLine>
   <SourceLine>Dim tmp As New clCompressedDataSerie(Self.name)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>For Each item_index As Integer In Self.items_index</SourceLine>
   <SourceLine>dim v as Variant </SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if item_index &gt;=0 then</SourceLine>
   <SourceLine>v = self.items_value_list(item_index)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>end if</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>tmp.append_element(v)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>Next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>Return tmp</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Function</SourceLine>
