   <SourceLine>Return</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End If</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>text_file = TextOutputStream.Create(the_destination)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>If name_as_header Then</SourceLine>
   <SourceLine>text_file.WriteLine Self.name</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End If</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>For i As Integer = 0 To self.upper_bound</SourceLine>
   <SourceLine>text_file.WriteLine self.get_element(i)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>Next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>text_file.close</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Sub</SourceLine>
