   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub append_element(the_item as Variant)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim item_entry as Integer</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if self.items_value_dict.HasKey(the_item) then</SourceLine>
   <SourceLine>item_entry = self.items_value_dict.Value(the_item)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>items_value_list.Append(the_item)</SourceLine>
   <SourceLine>item_entry = items_value_list.Ubound</SourceLine>
   <SourceLine>self.items_value_dict.Value(the_item) = item_entry</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>end if</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>items_index.Append(item_entry)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
