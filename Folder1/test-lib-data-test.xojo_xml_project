   <SourceLine>If tmp_data(i).InStr(kDbl_Quote) &gt;0 Or tmp_data(i).InStr(delimiter)&gt;0 Then</SourceLine>
   <SourceLine>tmp_data(i) = tmp_data(i).ReplaceAll(kDbl_Quote, kDbl_Quote+kDbl_Quote)</SourceLine>
   <SourceLine>tmp_data(i) = kDbl_Quote + tmp_data(i) + kDbl_Quote</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>Elseif always_add_quotes Then</SourceLine>
   <SourceLine>tmp_data(i) = kDbl_Quote + tmp_data(i) + kDbl_Quote</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End If</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>Next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>res = Join(tmp_data, delimiter)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>Return res</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Function</SourceLine>
