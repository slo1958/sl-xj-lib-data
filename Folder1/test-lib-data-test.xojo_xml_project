   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub append_table(the_table as clDataTable)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim length_before as integer = self.row_count</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>For Each src_tmp_column As clAbstractDataSerie In the_table.columns</SourceLine>
   <SourceLine>Dim column_name As String = src_tmp_column.name</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>Dim dst_tmp_column As  clAbstractDataSerie = Self.get_column(column_name)</SourceLine>
